  - faceImage: {fileID: -918932051, guid: 60293e33f8e3834458aad6794b510478, type: 3}
    onLeft: 0
    name: "\u5BFB\u8FF9\u8005"
    dialogueText: "\u8001\u4E08\uFF0C\u8FD9\u91CC\u5C31\u662F\u6D51\u5929\u5BFA\uFF1F\u4E3A\u4F55\u8FD9\u822C\u8352\u5E9F\uFF1F"
    hasToPause: 1
    isDone: 0
  - faceImage: {fileID: -1374765872, guid: 60293e33f8e3834458aad6794b510478, type: 3}
    onLeft: 1
    name: "\u8001\u4E08"
    dialogueText: "\u6570\u5341\u5E74\u524D\u5929\u8C61\u5F02\u52A8\uFF0C\u9547\u5E99\u4E4B\u5B9D\u6D51\u5929\u4EEA\u88AB\u9707\u574F\uFF0C\u5C71\u95E8\u4FBF\u81EA\u884C\u95ED\u5408\uFF0C\u518D\u65E0\u4EBA\u6709\u6280\u672F\u80FD\u8FDB\u5165\u3002"
    hasToPause: 1
    isDone: 0
  - faceImage: {fileID: -918932051, guid: 60293e33f8e3834458aad6794b510478, type: 3}
    onLeft: 0
    name: "\u5BFB\u8FF9\u8005"
    dialogueText: "\u90A3\u5982\u4F55\u624D\u80FD\u6253\u5F00\u5C71\u95E8\uFF1F"
    hasToPause: 1
    isDone: 0
  - faceImage: {fileID: -1374765872, guid: 60293e33f8e3834458aad6794b510478, type: 3}
    onLeft: 1
    name: "\u8001\u4E08"
    dialogueText: "\u8001\u592B\u4E0D\u77E5\u5177\u4F53\u6CD5\u5B50\uFF0C\u53EA\u77E5\u5C71\u95E8\u56E0\u6D51\u5929\u4EEA\u635F\u574F\u800C\u95ED\u5408\uFF0C\u5F02\u5E38\u575A\u56FA\uFF0C\u9700\u501F\u52A9\u7279\u5236\u5668\u7269\u624D\u80FD\u70B8\u5F00\u3002"
    hasToPause: 1
    isDone: 0
  - faceImage: {fileID: -1374765872, guid: 60293e33f8e3834458aad6794b510478, type: 3}
