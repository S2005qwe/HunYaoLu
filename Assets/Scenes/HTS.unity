  - faceImage: {fileID: -1374765872, guid: 60293e33f8e3834458aad6794b510478, type: 3}
    onLeft: 1
    name: "\u8001\u4E08"
    dialogueText: "\u5BFB\u8FF9\u8005\uFF1F\u597D\u4E45\uFF0C\u6CA1\u4EBA\u6765\u8FD9\u9759\u5C18\u5BFA\u4E86\u3002"
